parameters:
    level: 5
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - vendor/duanestorey/crossroads-core/src
        - vendor/duanestorey/crossroads-core/plugins
    scanDirectories:
        - vendor
    excludePaths:
        - vendor/duanestorey/crossroads-core/src/importers/*
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - '#Parameter .* has no type hint#'
        - '#Method .* has no return type#'
        - '#has no value type specified in iterable type array#'
        - '#class CR\\Importers\\WordPress#'
    dynamicConstantNames:
        - CROSSROADS_IS_COMPOSER
