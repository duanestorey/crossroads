{
    "name": "duanestorey/crossroads",
    "description": "Crossroads Static Site Generator",
    "license": "GPL-3.0-or-later",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "duanestorey/crossroads-core": "^1.0"
    },
    "autoload-dev": {
        "psr-4": {
            "CR\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "pestphp/pest": "^4.4"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "post-install-cmd": "git config core.hooksPath .githooks || true",
        "post-update-cmd": "git config core.hooksPath .githooks || true",
        "test": "pest",
        "lint": "phpstan analyse --memory-limit=512M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": ["@cs-check", "@lint", "@test"]
    }
}
